{
  "name": "carbon-shade-web",
  "version": "0.2.9",
  "private": true,
  "type": "module",
  "description": "Carbon Shade / 碳影: a 2.5D web combat prototype about borrowed power, AI-era agency, consequence, and the road back to one's own way.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "node scripts/typecheck.mjs",
    "build": "node scripts/build.mjs",
    "static:test": "node scripts/static-test.mjs",
    "smoke:pipeline": "node scripts/smoke-test.mjs",
    "validate:sprites": "node scripts/validate-sprites.mjs",
    "validate:assets": "node scripts/validate-assets.mjs",
    "validate:combat": "node scripts/validate-combat-boundaries.mjs",
    "browser:smoke": "playwright test tests/browser/combat-smoke.spec.ts",
    "analyze": "node scripts/analyze.mjs",
    "completion": "node scripts/completion.mjs",
    "audit:verify": "node scripts/audit-verify.mjs",
    "compile:schema": "node scripts/compile-schema.mjs",
    "compile:assets": "node --experimental-transform-types --no-warnings scripts/compile-runtime-assets.mjs",
    "closed-loop:status": "node scripts/closed-loop-status.mjs",
    "baseline": "node scripts/stage1-baseline.mjs",
    "baseline:pve": "node scripts/stage1-baseline.mjs --pve-full",
    "consistency": "node scripts/consistency-check.mjs"
  },
  "dependencies": {
    "flatbuffers": "^25.9.23",
    "iconv-lite": "^0.7.2",
    "phaser": "^3.90.0",
    "vite": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.19.17",
    "dependency-cruiser": "^17.4.0",
    "knip": "^6.14.1",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
